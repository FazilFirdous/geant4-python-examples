Options -Indexes

# Only allow image files
<FilesMatch "\.(jpg|jpeg|png|webp|gif)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

# Deny all other file types
<FilesMatch "^(?!.*\.(jpg|jpeg|png|webp|gif)$)">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Prevent PHP execution in uploads
<FilesMatch "\.(php|php3|php4|php5|phtml|pl|py|js|cgi)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
